# Groq API key for language model interactions (FREE - get from https://console.groq.com/keys)
GROQ_API_KEY=your_groq_key_here

# Rasa NLU server URL for intent and entity extraction
RASA_URL=http://localhost:5005

# Authentication token for Rasa server (optional)
RASA_TOKEN=

# Flask secret key for session encryption and CSRF protection
FLASK_SECRET_KEY=change_me_in_production

# Flask environment (development or production)
FLASK_ENV=development

# Port number for Flask server
FLASK_PORT=5000

# Minimum confidence threshold for intent classification (0.0-1.0)
CONFIDENCE_THRESHOLD=0.60

# Language model to use for responses (Groq: llama-3.3-70b-versatile, llama-3.1-8b-instant, gemma-2-9b-it)
LLM_MODEL=llama-3.3-70b-versatile

# Temperature for LLM responses (0.0-2.0, lower=more deterministic)
LLM_TEMPERATURE=0.3

# Path to documentation files for RAG system
DOCS_PATH=./data/docs

# Sentence transformer model for document embeddings
EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2
